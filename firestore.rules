rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{bookingId} {
      allow create: if !exists(/databases/$(database)/documents/bookings/$(bookingId))
        && !exists(/databases/$(database)/documents/blockedSlots/$(bookingId))
        && request.resource.data.status == "Pending"
        && request.resource.data.paymentStatus == "Unpaid"
        && request.resource.data.bladeCount is int
        && request.resource.data.bladeCount >= 0
        && request.resource.data.bladeCount <= 6
        && (
          (request.resource.data.jobType == "maintenance"
            && request.resource.data.bladeCount == 0
            && request.resource.data.serviceId in ["push-mower", "riding-mower", "zero-turn", "tractor"]
            && request.resource.data.date >= "2026-07-31"
            && request.resource.data.equipmentMake is string
            && request.resource.data.equipmentMake.size() > 0
            && request.resource.data.equipmentModel is string
            && request.resource.data.equipmentModel.size() > 0
            && request.resource.data.engineMake is string
            && request.resource.data.engineMake.size() > 0
            && request.resource.data.engineModel is string
            && request.resource.data.engineModel.size() > 0
            && request.resource.data.filterType in ["Standard residential", "Commercial canister", "Not sure"]
            && (
              (request.resource.data.serviceId == "push-mower" && request.resource.data.price == 45)
              || (request.resource.data.serviceId == "riding-mower" && request.resource.data.price == 75)
              || (request.resource.data.serviceId == "zero-turn" && request.resource.data.price == 85)
              || (request.resource.data.serviceId == "tractor" && request.resource.data.price == 115)
            ))
          ||
          (request.resource.data.jobType == "blade-changing"
            && request.resource.data.serviceId == "bush-hog"
            && request.resource.data.price == (request.resource.data.bladeCount * 25 < 30 ? 30 : request.resource.data.bladeCount * 25))
          ||
          (request.resource.data.jobType == "blade-changing"
            && request.resource.data.serviceId in ["push-mower", "riding-mower", "zero-turn"]
            && request.resource.data.price == (request.resource.data.bladeCount * 10 < 30 ? 30 : request.resource.data.bladeCount * 10))
          ||
          (request.resource.data.jobType == "sharpening"
            && request.resource.data.serviceId == "bush-hog"
            && request.resource.data.price == (request.resource.data.bladeCount * 40 < 30 ? 30 : request.resource.data.bladeCount * 40))
          ||
          (request.resource.data.jobType == "sharpening"
            && request.resource.data.serviceId in ["push-mower", "riding-mower", "zero-turn"]
            && request.resource.data.price == (request.resource.data.bladeCount * 20 < 30 ? 30 : request.resource.data.bladeCount * 20))
          ||
          (request.resource.data.jobType == "chainsaw-sharpening"
            && request.resource.data.bladeCount == 0
            && request.resource.data.date >= "2026-07-31"
            && request.resource.data.chainRemoval is bool
            && request.resource.data.barSize is string
            && request.resource.data.barSize.size() > 0
            && request.resource.data.chainPitch is string
            && request.resource.data.chainPitch.size() > 0
            && (
              (request.resource.data.serviceId == "chainsaw-up-to-16"
                && request.resource.data.price == 30)
              || (request.resource.data.serviceId == "chainsaw-18-20"
                && request.resource.data.price == 30)
              || (request.resource.data.serviceId == "chainsaw-24-28"
                && request.resource.data.price == 30)
              || (request.resource.data.serviceId == "chainsaw-32-36-plus"
                && request.resource.data.price == (request.resource.data.chainRemoval == true ? 35 : 30))
            ))
        )
        && request.resource.data.city in ["Washington Parish", "St. Tammany Parish", "Tangipahoa Parish"];
      allow read, update, delete: if request.auth != null;
    }

    match /blockedSlots/{slotId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /gallery/{photoId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
